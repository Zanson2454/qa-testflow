# console 与 portal 环境地址
CONSOLE_BASE_URL=https://console.example.com
PORTAL_BASE_URL=https://portal.example.com

# cookie 登录策略：优先读取 CONSOLE_COOKIE（或兼容 COOKIE/Cookie）
CONSOLE_COOKIE=t_iam_test=your_cookie_value

# 若未提供 Cookie，则回退到 storageState 文件
CONSOLE_STORAGE_STATE=.auth/console.storageState.json

# 必须指向「公开页面」配置功能的真实路由（不要仅填 /team/xxx）
CONSOLE_PUBLIC_PAGE_PATH=/team/your-team-id/your-app-path/to-public-page-settings

# 下拉中要选择的场景页名称（需与 console 中展示一致）
CONSOLE_SCENE_PAGE_NAME=AT_公开页面

# 可选：页面未加 data-testid 时，用下列变量对齐真实控件
# E2E_PUBLIC_PAGE_SELECT_TESTID=
# E2E_PUBLIC_PAGE_SAVE_TESTID=
# E2E_PUBLIC_PAGE_LINK_TESTID=
# E2E_PUBLIC_PAGE_SAVE_SUCCESS_TESTID=
# E2E_PORTAL_ROOT_TESTID=

PORTAL_PUBLIC_SUCCESS_TEXT=预约成功
PORTAL_NO_PERMISSION_TEXT=无权限
