# 说明：本文件不会被测试运行时读取，仅作「复制为 .env」的模板与字段说明。
# 真实配置请写在项目根目录 .env（已被 git 忽略）。
#
# 仅依赖 BASE_URL：console 从首页经菜单进入「公开页面」，无需 CONSOLE_PUBLIC_PAGE_PATH
CONSOLE_BASE_URL=https://console-test.app.terminus.io/team/1142
PORTAL_BASE_URL=https://portal.example.com

# cookie 登录：CONSOLE_COOKIE 或 Cookie（任选其一）
CONSOLE_COOKIE=t_iam_test=your_cookie_value

# 若未提供 Cookie，可回退 storageState
CONSOLE_STORAGE_STATE=.auth/console.storageState.json

# 以下均有默认值，仅当文案/门户名与默认不一致时再覆盖
# CONSOLE_LOGIN_SUCCESS_TEXT=欢迎登入系统~
# CONSOLE_PLATFORM_VERSION=3.0.2603-beta.0315
# CONSOLE_PORTAL_MENU_TEXT=门户管理
# CONSOLE_PORTAL_ENTRY_NAME=TERP 运营端
# CONSOLE_PORTAL_CONFIG_TEXT=门户配置
# CONSOLE_PUBLIC_PAGE_MENU_TEXT=公开页面

# 进入公开页面后下拉选择的场景页名称（默认 AT_公开页面，一般无需配置）
# CONSOLE_SCENE_PAGE_NAME=

# 可选：控件 testid 覆盖
# E2E_PUBLIC_PAGE_SELECT_TESTID=
# E2E_PUBLIC_PAGE_SAVE_TESTID=
# E2E_PUBLIC_PAGE_LINK_TESTID=
# E2E_PUBLIC_PAGE_SAVE_SUCCESS_TESTID=
# E2E_PORTAL_ROOT_TESTID=

PORTAL_PUBLIC_SUCCESS_TEXT=预约成功
PORTAL_NO_PERMISSION_TEXT=无权限
